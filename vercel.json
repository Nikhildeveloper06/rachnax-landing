{
    "framework": null,
    "buildCommand": null,
    "outputDirectory": ".",
    "routes": [
        { "handle": "filesystem" },

        { "src": "^/sitemap.xml$", "dest": "/sitemap.xml" },
        { "src": "^/robots.txt$", "dest": "/robots.txt" },

        { "src": "/(.*)", "dest": "/index.html" }
    ]
}